{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "typeRoots": ["./agent/npm/node_modules/@types"],
    "types": ["node"],
    "paths": {
      "typebox": ["./agent/npm/node_modules/typebox/build/index.d.mts"],
      "@earendil-works/pi-ai": ["./agent/npm/node_modules/@earendil-works/pi-ai/dist/index.d.ts"],
      "@earendil-works/pi-tui": ["./agent/npm/node_modules/@earendil-works/pi-tui/dist/index.d.ts"],
      "@earendil-works/pi-agent-core": ["/opt/homebrew/lib/node_modules/@earendil-works/pi-coding-agent/node_modules/@earendil-works/pi-agent-core/dist/index.d.ts"],
      "@earendil-works/pi-coding-agent": ["/opt/homebrew/lib/node_modules/@earendil-works/pi-coding-agent/dist/index.d.ts"],
      "@mariozechner/pi-ai": ["/opt/homebrew/lib/node_modules/openclaw/node_modules/@mariozechner/pi-ai/dist/index.d.ts"],
      "@mariozechner/pi-tui": ["/opt/homebrew/lib/node_modules/openclaw/node_modules/@mariozechner/pi-tui/dist/index.d.ts"],
      "@mariozechner/pi-agent-core": ["/opt/homebrew/lib/node_modules/openclaw/node_modules/@mariozechner/pi-agent-core/dist/index.d.ts"],
      "@mariozechner/pi-coding-agent": ["/opt/homebrew/lib/node_modules/openclaw/node_modules/@mariozechner/pi-coding-agent/dist/index.d.ts"]
    }
  },
  "include": ["agent/extensions/**/*.ts"]
}
